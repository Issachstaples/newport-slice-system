                        "single": "paragraph,strong,em,hyperlink"
                    }
                },
                "solution_title": {
                    "type": "Text",
                    "config": {
                        "label": "Solution Title",
                        "placeholder": "The Solution"
                    }
                },
                "solution_body": {
                    "type": "StructuredText",
                    "config": {
                        "label": "Solution Body",
                        "placeholder": "Describe how Newport solves the problem.",
                        "allowTargetBlank": false,
                        "single": "paragraph,strong,em,hyperlink"
                    }
                }
            },
            "items": {}
        }
    ]
