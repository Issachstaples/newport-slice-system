{
    "id": "problem_solution",
    "type": "SharedSlice",
    "name": "ProblemSolution",
    "description": "Two-panel section: a problem statement and a solution statement.",
    "variations": [
        {
            "id": "default",
            "name": "Default",
            "docURL": "...",
            "version": "initial",
            "description": "Default",
            "imageUrl": "",
            "primary": {
                "problem_title": {
                    "type": "Text",
                    "config": {
                        "label": "Problem Title",
                        "placeholder": "The Problem"
                    }
                },
                "problem_body": {
                    "type": "StructuredText",
                    "config": {
                        "label": "Problem Body",
