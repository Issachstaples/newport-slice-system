        "animation_mode": {
          "type": "Select",
          "config": {
            "label": "Animation Mode",
            "placeholder": "none",
            "options": [
              "none",
              "slide_up",
              "stagger",
              "fade_in"
            ],
            "default_value": "none"
          }
        },
        "tabs_style": {
          "type": "Select",
          "config": {
            "label": "Tabs Style",
            "placeholder": "none",
            "options": [
              "pills",
              "underline",
              "cards"
            ],
            "default_value": "pills"
          }
        },
        "content_style": {
          "type": "Select",
          "config": {
            "label": "Content Style",
            "placeholder": "none",
            "options": [
              "panel",
              "grid"
            ],
            "default_value": "panel"
          }
