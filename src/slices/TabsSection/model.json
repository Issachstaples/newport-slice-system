        "show_icons": {
          "type": "Boolean",
          "config": {
            "label": "Show Icons",
            "placeholder_false": "false",
            "placeholder_true": "true",
            "default_value": true
          }
        },
        "allow_wrap": {
          "type": "Boolean",
          "config": {
            "label": "Allow Wrap",
            "placeholder_false": "false",
            "placeholder_true": "true",
            "default_value": true
          }
        },
        "eyebrow": {
          "type": "Text",
          "config": {
            "label": "Eyebrow",
            "placeholder": "none"
          }
        },
        "headline": {
          "type": "Text",
          "config": {
            "label": "Headline",
            "placeholder": "Headline"
          }
        },
        "body": {
          "type": "StructuredText",
          "config": {
            "label": "Body",
            "placeholder": "Body",
            "allowTargetBlank": true,
            "single": "paragraph,strong,hyperlink"
          }
        },
        "tabs": {
          "type": "Group",
          "config": {
            "label": "Tabs",
            "repeat": true,
            "fields": {
              "tab_label": {
                "type": "Text",
                "config": {
                  "label": "Tab Label",
                  "placeholder": "Label"
                }
              },
              "tab_icon": {
                "type": "Select",
                "config": {
                  "label": "Tab Icon",
                  "placeholder": "none",
                  "options": [
                    "check",
                    "sparkles",
                    "bolt",
                    "shield",
                    "star",
                    "info",
                    "warning"
                  ],
                  "default_value": "check"
                }
              },
              "tab_badge": {
                "type": "Text",
                "config": {
                  "label": "Tab Badge",
                  "placeholder": "Badge"
                }
              },
              "tab_body": {
                "type": "StructuredText",
                "config": {
                  "label": "Tab Body",
                  "placeholder": "Body",
                  "allowTargetBlank": true,
                  "single": "paragraph,strong,hyperlink,list-item,o-list-item"
                }
              }
            }
          }
        }
