{
  "id": "tabs_section",
  "type": "SharedSlice",
  "name": "TabsSection",
  "description": "TabsSection",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "is_enabled": {
          "type": "Boolean",
          "config": {
            "label": "Is Enabled",
            "placeholder_false": "false",
            "placeholder_true": "true",
            "default_value": true
          }
        },
        "visual_mode": {
          "type": "Select",
          "config": {
            "label": "Visual Mode",
            "placeholder": "none",
            "options": [
              "none",
              "gradient_orb",
              "3d_helix"
            ],
            "default_value": "none"
          }
        },
        "section_padding": {
          "type": "Select",
          "config": {
            "label": "Section Padding",
            "placeholder": "none",
            "options": [
              "md",
              "sm",
              "lg",
              "none"
            ],
            "default_value": "md"
          }
        },
        "container_width": {
          "type": "Select",
          "config": {
            "label": "Container Width",
            "placeholder": "none",
            "options": [
              "standard",
              "wide",
              "full"
            ],
            "default_value": "standard"
          }
        },
        "align_mode": {
          "type": "Select",
          "config": {
            "label": "Align Mode",
            "placeholder": "none",
            "options": [
              "left",
              "center"
            ],
            "default_value": "left"
          }
