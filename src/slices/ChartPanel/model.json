{
  "id": "chart_panel",
  "type": "SharedSlice",
  "name": "ChartPanel",
  "description": "Benchmark chart panel with insight caption, disclaimer, and source citations.",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "section_title": {
          "type": "Text",
          "config": {
            "label": "Section Title",
            "placeholder": "Speed Wins"
          }
        },
        "section_body": {
          "type": "StructuredText",
          "config": {
            "label": "Section Body",
            "placeholder": "1\u20132 sentences contextualising the benchmark data.",
            "allowTargetBlank": false,
            "single": "paragraph,strong,em,hyperlink"
          }
        },
        "chart_type": {
          "type": "Select",
          "config": {
            "label": "Chart Type",
            "placeholder": "bar",
            "options": [
              "bar",
              "line",
              "area",
              "radial",
              "donut"
            ],
            "default_value": "bar"
          }
        },
        "chart_data_json": {
          "type": "Text",
          "config": {
            "label": "Chart Data JSON",
            "placeholder": "[{\"segment\":\"Retail\",\"lift_pct\":8.4}]"
          }
        },
        "chart_config_json": {
          "type": "Text",
          "config": {
            "label": "Chart Config JSON",
            "placeholder": "{\"lift_pct\":{\"label\":\"Conversion Lift (%)\"}}"
          }
        },
        "insight_caption": {
          "type": "StructuredText",
          "config": {
            "label": "Insight Caption",
            "placeholder": "One sentence takeaway. Benchmarks vary by industry and offer; results aren't guaranteed.",
            "allowTargetBlank": false,
            "single": "paragraph,strong,em"
          }
        }
      },
      "items": {
        "source_label": {
          "type": "Text",
          "config": {
            "label": "Source Label",
            "placeholder": "web.dev \u2014 Milliseconds Make Millions"
          }
        },
        "source_href": {
          "type": "Link",
          "config": {
            "label": "Source Link",
            "placeholder": "",
            "select": null,
            "allowTargetBlank": true,
            "allowText": false,
            "repeat": false
          }
        }
      }
    }
  ]
}
