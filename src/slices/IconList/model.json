{
  "id": "icon_list",
  "type": "SharedSlice",
  "name": "IconList",
  "description": "IconList",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "is_enabled": {
          "type": "Boolean",
          "config": {
            "label": "Is Enabled",
            "placeholder_false": "false",
            "placeholder_true": "true",
            "default_value": true
          }
        },
        "visual_mode": {
          "type": "Select",
          "config": {
            "label": "Visual Mode",
            "placeholder": "none",
            "options": [
              "none",
              "gradient_orb",
              "helix_3d"
            ]
          }
        },
        "section_padding": {
          "type": "Select",
          "config": {
            "label": "Section Padding",
            "placeholder": "none",
            "options": [
              "md",
              "sm",
              "lg",
              "none"
            ],
            "default_value": "md"
          }
        },
        "container_width": {
          "type": "Select",
          "config": {
            "label": "Container Width",
            "placeholder": "none",
            "options": [
              "standard",
              "wide",
              "full"
            ]
          }
        },
        "align_mode": {
          "type": "Select",
          "config": {
            "label": "Align Mode",
            "placeholder": "none",
            "options": [
              "left",
              "center"
            ],
            "default_value": "left"
          }
        },
        "density_mode": {
          "type": "Select",
          "config": {
            "label": "Density Mode",
            "placeholder": "none",
            "options": [
              "relaxed",
              "compact"
            ],
            "default_value": "relaxed"
          }
        },
        "eyebrow": {
          "type": "Text",
          "config": {
            "label": "Eyebrow",
            "placeholder": "none"
          }
        },
        "headline": {
          "type": "Text",
          "config": {
            "label": "Headline",
            "placeholder": "Headline"
          }
        },
        "body": {
          "type": "StructuredText",
          "config": {
            "label": "Body",
            "placeholder": "Body",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,hyperlink,list-item,o-list-item,em"
          }
        },
        "items": {
          "type": "Group",
          "config": {
            "label": "Items",
            "repeat": true,
            "fields": {
              "item_icon": {
                "type": "Select",
                "config": {
                  "label": "Item Icon",
                  "placeholder": "none",
                  "options": [
                    "check",
                    "sparkles",
                    "bolt",
                    "shield",
                    "star",
                    "info",
                    "warning"
                  ],
                  "default_value": "check"
                }
              },
              "item_title": {
                "type": "Text",
                "config": {
                  "label": "Item Title",
                  "placeholder": "none"
                }
              },
              "item_description": {
                "type": "StructuredText",
                "config": {
                  "label": "Item Description",
                  "placeholder": "none",
                  "allowTargetBlank": true,
                  "single": "paragraph,strong,em,hyperlink,list-item,o-list-item"
                }
              },
              "item_is_highlighted": {
                "type": "Boolean",
                "config": {
                  "label": "Item Is Highlighted",
                  "placeholder_false": "false",
                  "placeholder_true": "true",
                  "default_value": true
                }
              },
              "item_badge": {
                "type": "Text",
                "config": {
                  "label": "Item Badge",
                  "placeholder": "none"
                }
              }
            }
          }
        }
      },
      "items": {}
    }
  ]
}